<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_light">

    <!-- Gamepad View -->
    <com.openterface.keymod.GamepadView
        android:id="@+id/gamepad_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <!-- Control toggles row (center top) -->
    <LinearLayout
        android:id="@+id/toggle_row"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="8dp"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <!-- Button mode toggle -->
        <ToggleButton
            android:id="@+id/button_mode_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textOff="1 Button"
            android:textOn="2 Buttons"
            android:checked="false"
            android:textSize="10sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="2dp"
            android:minWidth="80dp"
            android:minHeight="28dp"
            android:background="@drawable/toggle_background" />

        <!-- Edit mode toggle -->
        <ToggleButton
            android:id="@+id/edit_mode_toggle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:textOff="Edit"
            android:textOn="Editing"
            android:checked="false"
            android:textSize="10sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="2dp"
            android:minWidth="60dp"
            android:minHeight="28dp"
            android:background="@drawable/toggle_background" />
    </LinearLayout>

    <!-- Done button for edit mode (hidden by default) -->
    <Button
        android:id="@+id/edit_done_btn"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="24dp"
        android:text="Done"
        android:visibility="gone" />

</FrameLayout>
