<?xml version="1.0" encoding="utf-8"?>
<!--
  Col 1-3: left panel (NumLk/*/  | 7 8 9 | 4 5 6 | 1 2 3 | 0 .)
  Col 4  : right panel (- | + | BSP | Enter x2 tall)
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="#1E1E1E"
    android:padding="3dp">

    <!-- Left panel: 3 columns x 5 rows -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="3"
        android:orientation="vertical">

        <!-- Row 1: NumLk, /, * -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn_numlock"  android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="NumLk" android:textSize="12sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background"  android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_divide"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="/"     android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background"  android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_multiply" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="*"     android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background"  android:theme="@style/ButtonTheme"/>
        </LinearLayout>

        <!-- Row 2: 7, 8, 9 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn_7" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="7" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_8" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="8" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_9" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="9" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
        </LinearLayout>

        <!-- Row 3: 4, 5, 6 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn_4" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="4" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_5" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="5" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_6" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="6" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
        </LinearLayout>

        <!-- Row 4: 1, 2, 3 -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn_1" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="1" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_2" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="2" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="3" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
        </LinearLayout>

        <!-- Row 5: 0 (wide), . -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:orientation="horizontal">
            <Button android:id="@+id/btn_0"   android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="2" android:layout_margin="2dp" android:text="0" android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
            <Button android:id="@+id/btn_dot" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:layout_margin="2dp" android:text="." android:textSize="30sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_key_background" android:theme="@style/ButtonTheme"/>
        </LinearLayout>

    </LinearLayout>

    <!-- Right panel single column: -, +, Backspace, Enter (2x tall) -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical">

        <Button android:id="@+id/btn_subtract" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="2dp" android:text="&#8722;" android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background" android:theme="@style/ButtonTheme"/>
        <Button android:id="@+id/btn_add"       android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="2dp" android:text="+"         android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background" android:theme="@style/ButtonTheme"/>
        <Button android:id="@+id/btn_backspace" android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="1" android:layout_margin="2dp" android:text="&#9003;"   android:textSize="26sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background" android:theme="@style/ButtonTheme"/>
        <Button android:id="@+id/btn_enter"     android:layout_width="match_parent" android:layout_height="0dp" android:layout_weight="2" android:layout_margin="2dp" android:text="Enter"     android:textSize="14sp" android:textStyle="bold" android:textColor="#000000" android:background="@drawable/numpad_fn_background" android:theme="@style/ButtonTheme"/>

    </LinearLayout>

</LinearLayout>
