<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="16dp"
    android:background="@drawable/presentation_card_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Touchpad"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/presentation_text_primary"
            android:gravity="center" />

        <Button
            android:id="@+id/btn_touchpad_close"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Close"
            android:textSize="12sp" />
    </LinearLayout>

    <com.openterface.keymod.TouchPadView
        android:id="@+id/touch_surface"
        android:layout_width="match_parent"
        android:layout_height="200dp"
        android:background="@drawable/touchpad_bg"
        android:layout_marginBottom="12dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Swipe to move · Tap to click · 2-finger right-click"
        android:textColor="@color/presentation_text_muted"
        android:textSize="12sp"
        android:gravity="center" />

</LinearLayout>
