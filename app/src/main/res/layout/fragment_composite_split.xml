<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/split_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Shared top scrolling panel -->
    <FrameLayout
        android:id="@+id/split_top_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Main content: stacked keyboards and touchpad for portrait -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Left Keyboard -->
        <com.openterface.keymod.CustomKeyboardView
            android:id="@+id/keyboard_view_left"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:keyBackground="@drawable/key_background"
            android:theme="@style/ButtonTheme"/>

        <!-- Touchpad Section (center) -->
        <LinearLayout
            android:id="@+id/touchpad_section"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="0.8"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/touchpad_background">

                <com.openterface.keymod.TouchPadView
                    android:id="@+id/touchPad"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:id="@+id/touchPadTips"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|center_horizontal"
                    android:gravity="center_horizontal"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:paddingTop="6dp"
                    android:paddingBottom="10dp"
                    android:background="@android:color/transparent"
                    android:text="@string/touch_pad_compact_initial"/>

                <TextView
                    android:id="@+id/touchPadHelpOverlay"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:translationY="@dimen/touchpad_help_overlay_shift_up_split"
                    android:layout_marginStart="12dp"
                    android:layout_marginEnd="12dp"
                    android:maxWidth="280dp"
                    android:visibility="gone"
                    android:alpha="0"
                    android:gravity="center_horizontal"
                    android:padding="6dp"
                    android:background="@android:color/transparent"
                    android:textColor="@color/text_primary"
                    android:textSize="14sp"
                    android:letterSpacing="0.01"
                    android:lineSpacingMultiplier="1.34" />

                <ImageButton
                    android:id="@+id/touchPadInfo"
                    android:layout_width="48dp"
                    android:layout_height="48dp"
                    android:layout_gravity="top|end"
                    android:layout_marginTop="2dp"
                    android:layout_marginEnd="2dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/touch_pad_info_content_description"
                    android:padding="12dp"
                    android:scaleType="fitCenter"
                    android:src="@drawable/ic_touchpad_info_24" />

            </FrameLayout>

            <!-- Toggle Handle (right side) -->
            <LinearLayout
                android:id="@+id/toggle_handle"
                android:layout_width="44dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:background="@color/background_light"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/toggle_handle_pill"
                    android:layout_width="40dp"
                    android:layout_height="4dp"
                    android:background="@drawable/toggle_handle_pill"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Right Keyboard -->
        <com.openterface.keymod.CustomKeyboardView
            android:id="@+id/keyboard_view_right"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:keyBackground="@drawable/key_background"
            android:theme="@style/ButtonTheme"/>

    </LinearLayout>

</LinearLayout>
