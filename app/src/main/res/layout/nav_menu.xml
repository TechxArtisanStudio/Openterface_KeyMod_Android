<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/sidebar_width"
    android:layout_height="match_parent"
    android:background="@color/sidebar_background"
    android:orientation="vertical"
    android:elevation="8dp">

    <!-- Sidebar Header (menu button + title, mirrors iOS) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/sidebar_close_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="Close menu" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KeyMod"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- Navigation Items -->
    <LinearLayout
        android:id="@+id/nav_keyboard_mouse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_keyboard_mouse"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/keyboard_mouse"
            android:tint="@color/card_selected_bg" />

        <TextView
            android:id="@+id/nav_text_keyboard_mouse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keyboard &amp; Mouse"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_numpad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_numpad"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/numpad"
            android:tint="@color/card_selected_bg" />

        <TextView
            android:id="@+id/nav_text_numpad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Numpad"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_shortcuts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_shortcuts"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/three_dots"
            android:tint="@color/card_selected_bg" />

        <TextView
            android:id="@+id/nav_text_shortcuts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shortcuts"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_macros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_macros"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/macros"
            android:tint="@color/card_selected_bg" />

        <TextView
            android:id="@+id/nav_text_macros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Macros"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_voice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_voice"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/voice"
            android:tint="@color/card_selected_bg" />

        <TextView
            android:id="@+id/nav_text_voice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Input"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Spacer -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="8dp" />

    <!-- Target OS selector -->
    <LinearLayout
        android:id="@+id/target_os_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingBottom="4dp">

        <TextView
            android:id="@+id/target_os_label"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Target OS"
            android:textSize="11sp"
            android:textStyle="bold"
            android:textColor="@color/text_secondary"
            android:paddingStart="20dp"
            android:paddingEnd="20dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:paddingBottom="8dp">

        <ImageButton
            android:id="@+id/nav_os_macos_button"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Target macOS"
            android:padding="8dp"
            android:src="@drawable/ic_os_macos"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/nav_os_windows_button"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Target Windows"
            android:padding="8dp"
            android:src="@drawable/ic_os_windows"
            android:tint="@color/text_secondary" />

        <ImageButton
            android:id="@+id/nav_os_linux_button"
            android:layout_width="48dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Target Linux"
            android:padding="8dp"
            android:src="@drawable/ic_os_linux"
            android:tint="@color/text_secondary" />

    </LinearLayout>
    </LinearLayout>

    <!-- LaunchPad Button (returns to LaunchPanel) -->
    <Button
        android:id="@+id/choose_mode_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="LaunchPad"
        android:textSize="14sp"
        android:textColor="@color/card_selected_bg"
        android:padding="@dimen/sidebar_item_padding"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="start|center_vertical"
        android:drawablePadding="@dimen/spacing_small"
        style="?android:attr/borderlessButtonStyle" />

    <!-- Settings Button -->
    <Button
        android:id="@+id/settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Settings"
        android:textSize="14sp"
        android:textColor="@color/text_primary"
        android:padding="@dimen/sidebar_item_padding"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="start|center_vertical"
        android:drawableStart="@drawable/ic_settings"
        android:drawablePadding="@dimen/spacing_small"
        style="?android:attr/borderlessButtonStyle" />

</LinearLayout>

