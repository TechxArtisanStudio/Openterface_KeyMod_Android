<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="@dimen/sidebar_width"
    android:layout_height="match_parent"
    android:background="@color/sidebar_background"
    android:orientation="vertical"
    android:elevation="8dp">

    <!-- Sidebar Header (menu button + title, mirrors iOS) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/sidebar_close_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:src="@drawable/ic_menu"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:tint="@color/text_primary"
            android:contentDescription="Close menu" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="KeyMod"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

    <!-- Navigation Items -->
    <LinearLayout
        android:id="@+id/nav_keyboard_mouse"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_keyboard_mouse"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/keyboard_mouse"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_keyboard_mouse"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Keyboard &amp; Mouse"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Presentation Mode -->
    <LinearLayout
        android:id="@+id/nav_presentation"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_presentation"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_presentation"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_presentation"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Presentation"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_gamepad"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_gamepad"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/gamepad"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_gamepad"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Gamepad"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_shortcuts"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_shortcuts"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/three_dots"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_shortcuts"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Shortcuts"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_macros"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_macros"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/macros"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_macros"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Macros"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <LinearLayout
        android:id="@+id/nav_voice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true">

        <ImageView
            android:id="@+id/nav_icon_voice"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/voice"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_voice"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Input"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Settings (Material gear icon; row matches mode items above) -->
    <LinearLayout
        android:id="@+id/settings_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="12dp"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:background="@drawable/nav_item_background_selector"
        android:clickable="true"
        android:focusable="true"
        android:contentDescription="@string/settings_title">

        <ImageView
            android:id="@+id/nav_icon_settings"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@drawable/ic_settings"
            android:importantForAccessibility="no"
            android:tint="?attr/colorPrimary" />

        <TextView
            android:id="@+id/nav_text_settings"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/settings_title"
            android:textSize="16sp"
            android:textColor="@color/text_primary"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Welcome & Guide (LaunchPanelActivity) -->
    <Button
        android:id="@+id/choose_mode_button"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/nav_welcome_guide"
        android:contentDescription="@string/nav_welcome_guide_content_description"
        android:textSize="14sp"
        android:textColor="?attr/colorPrimary"
        android:padding="@dimen/sidebar_item_padding"
        android:layout_marginStart="8dp"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="4dp"
        android:background="?attr/selectableItemBackground"
        android:gravity="start|center_vertical"
        android:drawablePadding="@dimen/spacing_small"
        style="?android:attr/borderlessButtonStyle" />

    <!-- Version Info -->
    <TextView
        android:id="@+id/version_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="v1.0"
        android:textSize="11sp"
        android:textColor="@color/text_secondary"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="4dp"
        android:paddingBottom="16dp"
        android:gravity="center" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>

