<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/composite_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Touchpad Section (top, flexible height) -->
    <LinearLayout
        android:id="@+id/touchpad_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical">

        <!-- TouchPad (fills remaining space in touchpad section) with center tips overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.openterface.keymod.TouchPadView
                android:id="@+id/touchPad"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/touchpad_background"/>

            <TextView
                android:id="@+id/touchPadTips"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:gravity="center"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:padding="12dp"
                android:background="@android:color/transparent"
                android:text="Touch Pad&#10;Drag Mode OFF&#10;Single tap -> Click&#10;Double tap -> Double click&#10;Two finger tap -> Right click&#10;Two finger drag -> Scroll&#10;Long press -> Toggle drag mode"/>

        </FrameLayout>

    </LinearLayout>

    <!-- Toggle Handle (tap to cycle display modes: both / keyboard only / touchpad only) -->
    <LinearLayout
        android:id="@+id/toggle_handle"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:gravity="center"
        android:background="@color/background_light"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/toggle_handle_pill"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@drawable/toggle_handle_pill"/>

    </LinearLayout>

    <!-- Keyboard Section (bottom, larger share so all rows fit) -->
    <com.openterface.keymod.CustomKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:keyBackground="@drawable/key_background"
        android:theme="@style/ButtonTheme"/>

</LinearLayout>