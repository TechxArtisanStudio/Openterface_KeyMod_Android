<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/composite_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Touchpad Section (top, expanded height for better gesture room) -->
    <LinearLayout
        android:id="@+id/touchpad_section"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.25"
        android:orientation="vertical">

        <!-- TouchPad with footer hint overlay -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <com.openterface.keymod.TouchPadView
                android:id="@+id/touchPad"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@color/touchpad_background"/>

            <TextView
                android:id="@+id/touchPadTips"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|center_horizontal"
                android:gravity="center_horizontal"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="8dp"
                android:paddingBottom="16dp"
                android:background="@android:color/transparent"
                android:text="@string/touch_pad_compact_initial"/>

            <TextView
                android:id="@+id/touchPadHelpOverlay"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:translationY="@dimen/touchpad_help_overlay_shift_up"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                android:maxWidth="340dp"
                android:visibility="gone"
                android:alpha="0"
                android:gravity="center_horizontal"
                android:padding="8dp"
                android:background="@android:color/transparent"
                android:textColor="@color/text_primary"
                android:textSize="16sp"
                android:letterSpacing="0.01"
                android:lineSpacingMultiplier="1.34" />

            <ImageButton
                android:id="@+id/touchPadInfo"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_gravity="top|end"
                android:layout_marginTop="4dp"
                android:layout_marginEnd="4dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/touch_pad_info_content_description"
                android:padding="12dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_touchpad_info_24" />

        </FrameLayout>

    </LinearLayout>

    <!-- Toggle Handle (tap to cycle display modes: both / keyboard only / touchpad only) -->
    <LinearLayout
        android:id="@+id/toggle_handle"
        android:layout_width="match_parent"
        android:layout_height="@dimen/toggle_handle_height"
        android:gravity="center"
        android:background="@color/background_light"
        android:clickable="true"
        android:focusable="true">

        <View
            android:id="@+id/toggle_handle_pill"
            android:layout_width="40dp"
            android:layout_height="4dp"
            android:background="@drawable/toggle_handle_pill"/>

    </LinearLayout>

    <!-- Keyboard Section (bottom, slightly reduced so touchpad reaches closer to top bar) -->
    <com.openterface.keymod.CustomKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2.15"
        android:paddingTop="@dimen/keyboard_outer_padding_top"
        android:paddingBottom="@dimen/keyboard_outer_padding_bottom"
        android:keyBackground="@drawable/key_background"
        android:theme="@style/ButtonTheme"/>

</LinearLayout>