<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/presentation_bg">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/tool_carousel"
        android:fillViewport="true">

        <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- Timer & Pace Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/presentation_card_bg"
            android:padding="16dp"
            android:layout_marginTop="12dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_pace_label"
                android:textColor="@color/presentation_text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Timer Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_timer"
                        android:tint="@color/presentation_primary"
                        android:contentDescription="Timer"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/timer_remaining"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="25:00"
                                android:textColor="@color/presentation_text_primary"
                                android:textSize="32sp"
                                android:textStyle="bold"
                                android:fontFamily="sans-serif-light" />

                            <ImageButton
                                android:id="@+id/btn_edit_timer"
                                android:layout_width="28dp"
                                android:layout_height="28dp"
                                android:layout_marginStart="8dp"
                                android:src="@drawable/ic_edit"
                                android:tint="@color/presentation_text_muted"
                                android:background="?attr/selectableItemBackgroundBorderless"
                                android:contentDescription="Edit timer" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:id="@+id/timer_label"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/remaining"
                                android:textColor="@color/presentation_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/timer_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" of 25:00"
                                android:textColor="@color/presentation_text_muted"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>

                    <ImageButton
                        android:id="@+id/btn_timer_start"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="16dp"
                        android:src="@drawable/ic_play"
                        android:tint="@android:color/white"
                        android:background="@drawable/timer_start_button"
                        android:contentDescription="Start timer" />

                    <ImageButton
                        android:id="@+id/btn_timer_reset"
                        android:layout_width="56dp"
                        android:layout_height="56dp"
                        android:layout_marginStart="8dp"
                        android:src="@drawable/ic_reset"
                        android:tint="@color/presentation_text_primary"
                        android:background="@drawable/presentation_action_button"
                        android:contentDescription="Reset timer" />
                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- NEXT / Previous Side by Side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_previous"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:text="@string/previous"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_primary_button"
                    android:drawableEnd="@drawable/caret_left_fill"
                    android:drawablePadding="8dp"
                    android:drawableTint="@android:color/white"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <TextView
                    android:id="@+id/hint_previous"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="← Left Arrow"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="160dp"
                    android:text="@string/next"
                    android:textColor="@android:color/white"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_primary_button"
                    android:drawableEnd="@drawable/caret_right_fill"
                    android:drawablePadding="8dp"
                    android:drawableTint="@android:color/white"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />

                <TextView
                    android:id="@+id/hint_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="→ Right Arrow"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons Row (Play / Black Screen) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_play"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:minHeight="100dp"
                    android:text="@string/play"
                    android:textColor="@android:color/white"
                    android:textSize="22sp"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_primary_button"
                    android:drawableEnd="@drawable/ic_play"
                    android:drawablePadding="8dp"
                    android:drawableTint="@android:color/white"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />

                <TextView
                    android:id="@+id/hint_play"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⌥⌘P / ESC"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_black_screen"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:minHeight="100dp"
                    android:text="@string/black_screen"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_action_button"
                    android:drawableTop="@drawable/ic_black_screen"
                    android:drawablePadding="4dp"
                    android:drawableTint="@android:color/white"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/hint_black_screen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="B"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons Row (Laser / Pointer) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_laser"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:minHeight="100dp"
                    android:text="@string/laser"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_action_button"
                    android:drawableTop="@drawable/ic_laser"
                    android:drawablePadding="4dp"
                    android:drawableTint="@android:color/white"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/hint_laser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="⌘Tab (tap/cycle/double-tap)"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_pointer"
                    android:layout_width="match_parent"
                    android:layout_height="200dp"
                    android:minHeight="100dp"
                    android:text="@string/pointer"
                    android:textColor="@android:color/white"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_action_button"
                    android:drawableTop="@drawable/ic_pointer"
                    android:drawablePadding="4dp"
                    android:drawableTint="@android:color/white"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/hint_pointer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Mouse move / click / right-click"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    </ScrollView>

    <!-- Presentation Tool Carousel (Fixed at Bottom) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tool_carousel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="@color/presentation_bg" />

</RelativeLayout>
