<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/presentation_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="24dp">

        <!-- Top Status Bar -->
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp">

            <!-- Connected status -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true">

                <View
                    android:layout_width="8dp"
                    android:layout_height="8dp"
                    android:background="@drawable/status_dot_connected"
                    android:layout_marginEnd="6dp" />

                <TextView
                    android:id="@+id/connection_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Connected"
                    android:textColor="@color/presentation_text_primary"
                    android:textSize="14sp" />
            </LinearLayout>

            <!-- Battery and Settings (right side) -->
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true">

                <TextView
                    android:id="@+id/battery_level"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="80%"
                    android:textColor="@color/presentation_text_primary"
                    android:textSize="14sp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/settings_button"
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_settings"
                    android:tint="@color/presentation_text_primary"
                    android:contentDescription="Settings" />
            </LinearLayout>
        </RelativeLayout>

        <!-- Presentation Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/presentation_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="12dp">

            <!-- Card Header -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/slide_progress_label"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true" />

                <Button
                    android:id="@+id/btn_list"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="@string/list"
                    android:textColor="@color/presentation_text_secondary"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:background="@drawable/presentation_list_button"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:drawableStart="@drawable/ic_list"
                    android:drawablePadding="4dp"
                    android:drawableTint="@color/presentation_text_secondary" />
            </RelativeLayout>

            <!-- Slide Info -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_alignParentStart="true">

                    <TextView
                        android:id="@+id/slide_number"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Slide 1 / 1"
                        android:textColor="@color/presentation_text_primary"
                        android:textSize="28sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/slide_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Presentation"
                        android:textColor="@color/presentation_text_secondary"
                        android:textSize="18sp"
                        android:layout_marginTop="2dp" />
                </LinearLayout>
            </RelativeLayout>

            <!-- Slide Progress Dots -->
            <LinearLayout
                android:id="@+id/slide_progress_dots"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginBottom="8dp" />

            <!-- Percentage Labels -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:layout_alignParentStart="true" />

                <TextView
                    android:id="@+id/slide_percentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    android:textColor="@color/presentation_primary"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:layout_centerHorizontal="true" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="100%"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="11sp"
                    android:layout_alignParentEnd="true" />
            </RelativeLayout>
        </LinearLayout>

        <!-- Timer & Pace Card -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/presentation_card_bg"
            android:padding="16dp"
            android:layout_marginBottom="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/timer_pace_label"
                android:textColor="@color/presentation_text_muted"
                android:textSize="12sp"
                android:textStyle="bold"
                android:letterSpacing="0.1"
                android:layout_marginBottom="12dp" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <!-- Timer Section -->
                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="40dp"
                        android:layout_height="40dp"
                        android:src="@drawable/ic_timer"
                        android:tint="@color/presentation_primary"
                        android:contentDescription="Timer"
                        android:layout_marginEnd="12dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">

                        <TextView
                            android:id="@+id/timer_remaining"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="25:00"
                            android:textColor="@color/presentation_text_primary"
                            android:textSize="32sp"
                            android:textStyle="bold"
                            android:fontFamily="sans-serif-light" />

                        <LinearLayout
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical">

                            <TextView
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="@string/remaining"
                                android:textColor="@color/presentation_text_secondary"
                                android:textSize="14sp" />

                            <TextView
                                android:id="@+id/timer_total"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text=" of 25:00"
                                android:textColor="@color/presentation_text_muted"
                                android:textSize="14sp" />
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>

                <!-- Pace Gauge -->
                <com.openterface.keymod.PaceGaugeView
                    android:id="@+id/pace_gauge"
                    android:layout_width="80dp"
                    android:layout_height="80dp"
                    android:layout_marginStart="16dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- NEXT Button (Large Blue) -->
        <Button
            android:id="@+id/btn_next"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:text="@string/next"
            android:textColor="@android:color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:textAllCaps="false"
            android:background="@drawable/presentation_primary_button"
            android:layout_marginBottom="12dp"
            android:drawableEnd="@drawable/caret_right_fill"
            android:drawablePadding="8dp"
            android:drawableTint="@android:color/white"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />

        <!-- Action Buttons Grid (2x2) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="12dp">

            <Button
                android:id="@+id/btn_previous"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:minHeight="84dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/previous"
                android:textColor="@color/presentation_text_primary"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/presentation_action_button"
                android:drawableTop="@drawable/caret_left_fill"
                android:drawablePadding="4dp"
                android:drawableTint="@color/presentation_text_secondary"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_black_screen"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:minHeight="84dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/black_screen"
                android:textColor="@color/presentation_text_primary"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/presentation_action_button"
                android:drawableTop="@drawable/ic_black_screen"
                android:drawablePadding="4dp"
                android:drawableTint="@color/presentation_text_secondary"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="16dp">

            <Button
                android:id="@+id/btn_laser"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:minHeight="84dp"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="@string/laser"
                android:textColor="@color/presentation_text_primary"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/presentation_action_button"
                android:drawableTop="@drawable/ic_laser"
                android:drawablePadding="4dp"
                android:drawableTint="@color/presentation_red"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />

            <Button
                android:id="@+id/btn_pointer"
                android:layout_width="0dp"
                android:layout_height="84dp"
                android:minHeight="84dp"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/pointer"
                android:textColor="@color/presentation_text_primary"
                android:textSize="13sp"
                android:textAllCaps="false"
                android:background="@drawable/presentation_action_button"
                android:drawableTop="@drawable/ic_pointer"
                android:drawablePadding="4dp"
                android:drawableTint="@color/presentation_purple"
                android:paddingTop="12dp"
                android:paddingBottom="12dp" />
        </LinearLayout>

        <!-- Help Text -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:paddingStart="24dp"
            android:paddingEnd="24dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/tap_center_next"
                android:textColor="@color/presentation_text_muted"
                android:textSize="12sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/swipe_prev_next"
                android:textColor="@color/presentation_text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/long_press_laser"
                android:textColor="@color/presentation_text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/hold_move_pointer"
                android:textColor="@color/presentation_text_muted"
                android:textSize="12sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
