<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/presentation_bg">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/tool_carousel"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="0dp"
        android:paddingBottom="12dp">

        <!-- Timer & Pace Card -->
        <FrameLayout
            android:id="@+id/timer_card_container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/presentation_card_bg"
            android:layout_marginTop="0dp"
            android:layout_marginBottom="16dp"
            android:clipToOutline="true">

            <View
                android:id="@+id/timer_progress_fill"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_gravity="start"
                android:background="@color/presentation_timer_progress_fill" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/timer_header_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/timer_pace_label"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1" />

                <TextView
                    android:id="@+id/timer_status_text"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="remaining of 25:00"
                    android:textColor="@color/presentation_text_secondary"
                    android:textSize="13sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="end" />
            </LinearLayout>

            <TextView
                android:id="@+id/timer_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center_horizontal"
                android:layout_marginTop="6dp"
                android:text="25:00"
                android:textColor="@color/presentation_text_primary"
                android:textSize="46sp"
                android:textStyle="bold"
                android:fontFamily="sans-serif-light" />
            </LinearLayout>
        </FrameLayout>

        <!-- NEXT / Previous Side by Side -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="2"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_previous"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/previous"
                    android:textColor="@color/presentation_button_content"
                    android:textSize="20sp"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="12sp"
                    android:autoSizeMaxTextSize="20sp"
                    android:autoSizeStepGranularity="1sp"
                    android:background="@drawable/presentation_primary_button"
                    android:drawableEnd="@drawable/caret_left_fill"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/presentation_button_content"
                    android:paddingStart="16dp"
                    android:paddingEnd="16dp" />

                <TextView
                    android:id="@+id/hint_previous"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="← Left Arrow / Home\nFirst Slide"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="10sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="2"
                android:layout_marginStart="4dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_next"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/next"
                    android:textColor="@color/presentation_button_content"
                    android:textSize="28sp"
                    android:textStyle="bold"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="16sp"
                    android:autoSizeMaxTextSize="28sp"
                    android:autoSizeStepGranularity="1sp"
                    android:background="@drawable/presentation_primary_button"
                    android:drawableEnd="@drawable/caret_right_fill"
                    android:drawablePadding="8dp"
                    android:drawableTint="@color/presentation_button_content"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp" />

                <TextView
                    android:id="@+id/hint_next"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="→ Right Arrow / End\nLast Slide"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="10sp"
                    android:maxLines="2"
                    android:ellipsize="end"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons Row (Play / Black Screen) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_play"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/play"
                    android:textColor="@color/presentation_button_content"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:maxLines="2"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="16sp"
                    android:autoSizeStepGranularity="1sp"
                    android:background="@drawable/presentation_primary_button"
                    android:gravity="center"
                    android:paddingStart="8dp"
                    android:paddingEnd="8dp" />

                <TextView
                    android:id="@+id/hint_play"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="⌥⌘P / ESC"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_black_screen"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/hide_screen_multiline"
                    android:textColor="@color/presentation_button_content"
                    android:textSize="14sp"
                    android:textAllCaps="false"
                    android:maxLines="2"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="14sp"
                    android:autoSizeStepGranularity="1sp"
                    android:background="@drawable/presentation_action_button"
                    android:gravity="center"
                    android:paddingStart="6dp"
                    android:paddingEnd="6dp" />

                <TextView
                    android:id="@+id/hint_black_screen"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="B"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

        <!-- Action Buttons Row (Laser / Pointer) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_laser"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/laser"
                    android:textColor="@color/presentation_button_content"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="16sp"
                    android:autoSizeStepGranularity="1sp"
                    android:background="@drawable/presentation_action_button"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/hint_laser"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="⌘Tab (tap/cycle/double-tap)"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center" />
            </LinearLayout>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="4dp"
                android:orientation="vertical">

                <Button
                    android:id="@+id/btn_pointer"
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    android:minHeight="0dp"
                    android:text="@string/pointer"
                    android:textColor="@color/presentation_button_content"
                    android:textSize="16sp"
                    android:textAllCaps="false"
                    android:maxLines="1"
                    android:autoSizeTextType="uniform"
                    android:autoSizeMinTextSize="10sp"
                    android:autoSizeMaxTextSize="16sp"
                    android:autoSizeStepGranularity="1sp"
                    android:background="@drawable/presentation_action_button"
                    android:paddingTop="8dp"
                    android:paddingBottom="4dp" />

                <TextView
                    android:id="@+id/hint_pointer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="2dp"
                    android:text="Mouse move / click / right-click"
                    android:textColor="@color/presentation_text_muted"
                    android:textSize="10sp"
                    android:maxLines="1"
                    android:ellipsize="end"
                    android:gravity="center" />
            </LinearLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Presentation Tool Carousel (Fixed at Bottom) -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/tool_carousel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="12dp"
        android:background="@color/presentation_bg" />

</RelativeLayout>
