<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp"
        android:background="@color/white"
        android:elevation="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Voice Input"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Speech-to-text with Whisper AI"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Status -->
    <TextView
        android:id="@+id/status_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ready - Set API key in Settings"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/primary"
        android:padding="16dp"
        android:background="@color/white"
        android:layout_marginTop="8dp" />

    <!-- Waveform Visualization -->
    <ImageView
        android:id="@+id/waveform_view"
        android:layout_width="match_parent"
        android:layout_height="100dp"
        android:src="@drawable/ic_voice"
        android:scaleType="centerInside"
        android:padding="16dp"
        android:background="@color/white"
        android:contentDescription="Audio waveform" />

    <!-- Progress Bar -->
    <ProgressBar
        android:id="@+id/progress_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:visibility="gone"
        style="@style/Widget.AppCompat.ProgressBar.Horizontal"
        android:layout_margin="16dp" />

    <!-- Transcribed Text -->
    <EditText
        android:id="@+id/transcribed_text"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:hint="Transcribed text will appear here..."
        android:gravity="top|start"
        android:padding="16dp"
        android:background="@android:drawable/edit_text"
        android:layout_margin="16dp"
        android:inputType="textMultiLine"
        android:scrollbars="vertical"
        android:fontFamily="sans-serif"
        android:textSize="16sp" />

    <!-- Action Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp">

        <Button
            android:id="@+id/record_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:text="🎤 Record"
            android:textSize="18sp"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button" />

        <Button
            android:id="@+id/paste_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="📤 Send"
            android:layout_marginEnd="8dp"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

        <Button
            android:id="@+id/clear_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🗑 Clear"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton" />

    </LinearLayout>

    <!-- Instructions -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="1. Set Whisper API key in Settings\n2. Tap Record and speak\n3. Text appears automatically\n4. Tap Send to type on connected device"
        android:textSize="13sp"
        android:textColor="@color/text_secondary"
        android:padding="16dp"
        android:background="@color/primary_light"
        android:layout_margin="16dp" />

</LinearLayout>
