<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="2dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <TextView
            android:id="@+id/textView"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="3"
            android:text="this is textView"
            android:gravity="center">
        </TextView>

        <android.widget.Button
            android:id="@+id/keyBoard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/keyboard"
            android:scaleType="fitCenter"
            android:text="@string/KeyBoard"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/mouse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/mouse2"
            android:scaleType="fitCenter"
            android:text="@string/Mouse"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/keyBoardMouse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/keyboard_mouse"
            android:scaleType="fitCenter"
            android:text="@string/CompositeMode"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/question"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/question_lg"
            android:scaleType="fitCenter"
            android:text="@string/Instructions"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/info_lg"
            android:scaleType="fitCenter"
            android:text="@string/About"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

    </LinearLayout>

    <com.example.dual_modekeyboard.CustomKeyboardView
        android:id="@+id/keyboard_view"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="9"
        android:layout_gravity="center_horizontal"
        android:keyBackground="@drawable/key_background"
        android:theme="@style/ButtonTheme" />

</LinearLayout>