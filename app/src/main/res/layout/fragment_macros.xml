<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp"
        android:background="@color/header_background"
        android:elevation="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Macros"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />

        <ImageButton
            android:id="@+id/edit_mode_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Edit macros"
            android:src="@android:drawable/ic_menu_edit"
            android:tint="@color/text_secondary"
            android:layout_marginEnd="8dp" />

        <ImageButton
            android:id="@+id/add_macro_button"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="@android:color/transparent"
            android:contentDescription="Add macro"
            android:src="@android:drawable/ic_input_add"
            android:tint="@color/primary" />
    </LinearLayout>

    <GridView
        android:id="@+id/macros_gridview"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:numColumns="3"
        android:stretchMode="columnWidth"
        android:gravity="center"
        android:horizontalSpacing="12dp"
        android:verticalSpacing="12dp"
        android:padding="16dp"
        android:clipToPadding="false" />

    <TextView
        android:id="@+id/empty_textview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="No macros yet\nTap + to add one"
        android:textSize="16sp"
        android:textColor="@color/text_secondary"
        android:gravity="center"
        android:visibility="gone"
        android:layout_margin="24dp" />

</LinearLayout>
