<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <Space
        android:layout_width="match_parent"
        android:layout_height="22dp" />

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:paddingTop="20dp"
        android:gravity="center">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Welcome to KeyMod"
            android:textSize="32sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary"
            android:fontFamily="sans-serif-medium" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/launch_panel_subtitle"
            android:textSize="16sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_secondary"
            android:layout_marginTop="8dp"
            android:gravity="center"
            android:textAlignment="center" />

    </LinearLayout>

    <!-- Mode cards: scroll when header + footer leave too little height for weighted cells -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true"
        android:scrollbars="vertical"
        android:clipToPadding="false"
        android:requiresFadingEdge="vertical"
        android:fadingEdgeLength="22dp">

        <GridLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:padding="14dp"
            android:paddingBottom="16dp"
            android:alignmentMode="alignMargins">

        <!-- Keyboard & Mouse Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/keyboard_mouse_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/keyboard_mouse"
                    android:contentDescription="Keyboard and Mouse"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Keyboard &amp; Mouse"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Compose Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/compose_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_edit"
                    android:contentDescription="@string/compose_mode_title"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/compose_mode_title"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Presentation Card (order matches side nav) -->
        <androidx.cardview.widget.CardView
            android:id="@+id/presentation_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/ic_presentation"
                    android:contentDescription="Presentation"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Presentation"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Gamepad Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/gamepad_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/gamepad"
                    android:contentDescription="Gamepad"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Gamepad"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Shortcuts Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/shortcuts_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/three_dots"
                    android:contentDescription="Shortcuts"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Shortcuts"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Macros Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/macros_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/macros"
                    android:contentDescription="Macros"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Macros"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        <!-- Voice Card -->
        <androidx.cardview.widget.CardView
            android:id="@+id/voice_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnSpan="2"
            android:layout_columnWeight="1"
            android:layout_margin="8dp"
            app:cardCornerRadius="12dp"
            app:cardElevation="2dp"
            app:cardBackgroundColor="@android:color/transparent"
            android:clickable="true"
            android:focusable="true">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="112dp"
                android:orientation="vertical"
                android:gravity="center"
                android:paddingTop="10dp"
                android:paddingBottom="14dp"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                android:clipToPadding="false"
                android:clipChildren="false"
                android:background="@drawable/card_background_selector">

                <ImageView
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@drawable/voice"
                    android:contentDescription="Voice Input"
                    android:tint="@color/card_icon_tint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Voice Input"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:textColor="@color/card_text_color"
                    android:gravity="center"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="2dp" />

            </LinearLayout>

        </androidx.cardview.widget.CardView>

        </GridLayout>

    </androidx.core.widget.NestedScrollView>

    <TextView
        android:id="@+id/show_tutorial_link"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="2dp"
        android:text="@string/show_tutorial_link"
        android:textSize="14sp"
        android:textStyle="bold"
        android:textColor="?attr/colorPrimary"
        android:paddingTop="6dp"
        android:paddingBottom="3dp"
        android:paddingStart="8dp"
        android:paddingEnd="8dp" />

    <TextView
        android:id="@+id/launch_panel_credit"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:layout_marginBottom="6dp"
        android:paddingHorizontal="20dp"
        android:gravity="center"
        android:text="@string/launch_panel_credit"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:textColorLink="?attr/colorPrimary"
        android:autoLink="web"
        android:lineSpacingMultiplier="1.15" />

    <!-- Footer -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="10dp"
        android:paddingBottom="32dp"
        android:background="@color/background_light">

        <CheckBox
            android:id="@+id/remember_choice_checkbox"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/launch_panel_remember_choice"
            android:textSize="14sp"
            android:textColor="@color/text_primary" />

        <Button
            android:id="@+id/start_button"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="12dp"
            android:text="@string/launch_panel_start"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:background="@drawable/button_blue_bg"
            android:stateListAnimator="@null" />

        <Button
            android:id="@+id/skip_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="8dp"
            android:text="@string/launch_panel_skip"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorPrimary"
            android:background="@drawable/button_skip_bg"
            android:stateListAnimator="@null" />

    </LinearLayout>

</LinearLayout>
