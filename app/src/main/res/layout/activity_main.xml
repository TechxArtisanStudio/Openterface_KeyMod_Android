<?xml version="1.0" encoding="utf-8"?>
<androidx.drawerlayout.widget.DrawerLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/drawer_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- Main content -->
    <FrameLayout
        android:id="@+id/main_content_wrapper"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header with Connection and Menu buttons -->
        <RelativeLayout
            android:id="@+id/header_layout"
            android:layout_width="match_parent"
            android:layout_height="@dimen/header_height"
            android:padding="@dimen/header_padding"
            android:background="@color/header_background"
            android:elevation="@dimen/header_elevation">

            <!-- Menu Button (Left side - iOS style) -->
            <ImageButton
                android:id="@+id/menu_button"
                android:layout_width="@dimen/header_icon_size"
                android:layout_height="@dimen/header_icon_size"
                android:layout_alignParentStart="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_menu"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="@string/menu"
                android:padding="@dimen/button_icon_padding"
                android:tint="@color/text_primary"/>

            <!-- App Title (between menu and header end cluster) -->
            <TextView
                android:id="@+id/app_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_toEndOf="@id/menu_button"
                android:layout_toStartOf="@id/header_end_cluster"
                android:layout_centerVertical="true"
                android:text="@string/app_name"
                android:textSize="@dimen/header_title_size"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:paddingStart="@dimen/spacing_small"
                android:paddingEnd="@dimen/spacing_small"
                android:fontFamily="sans-serif-medium"
                android:maxLines="1"
                android:ellipsize="end"/>

            <!-- Target OS + connection (right side) -->
            <LinearLayout
                android:id="@+id/header_end_cluster"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <ImageButton
                    android:id="@+id/target_os_header_button"
                    android:layout_width="@dimen/header_icon_size"
                    android:layout_height="@dimen/header_icon_size"
                    android:layout_marginEnd="@dimen/spacing_tiny"
                    android:src="@drawable/ic_os_macos"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:contentDescription="@string/target_os_header_cd"
                    android:padding="@dimen/button_icon_padding"
                    android:tint="@color/text_secondary"/>

                <LinearLayout
                    android:id="@+id/connection_container"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:gravity="center"
                    android:clickable="true"
                    android:focusable="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:minWidth="@dimen/header_icon_size"
                    android:minHeight="@dimen/header_icon_size"
                    android:padding="4dp">

                    <ImageView
                        android:id="@+id/connection_button"
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_bluetooth"
                        android:tint="@color/text_secondary"
                        android:contentDescription="@string/connection"/>

                    <ImageView
                        android:id="@+id/signal_bars"
                        android:layout_width="24dp"
                        android:layout_height="12dp"
                        android:layout_marginTop="1dp"
                        android:src="@drawable/ic_signal_bars"
                        android:tint="@color/primary"
                        android:visibility="gone"
                        android:contentDescription="Signal strength"/>

                </LinearLayout>

            </LinearLayout>

        </RelativeLayout>

        <!-- Existing button bar (with USB and Bluetooth removed) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1.1"
            android:orientation="horizontal"
            android:paddingTop="3dp"
            android:visibility="gone">

            <android.widget.Button
                android:id="@+id/keyBoard"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@android:color/transparent"
                android:drawableTop="@drawable/keyboard"
                android:scaleType="fitCenter"
                android:text="@string/KeyBoard"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:theme="@style/FontStyle"/>

            <android.widget.Button
                android:id="@+id/mouse"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@android:color/transparent"
                android:drawableTop="@drawable/mouse2"
                android:scaleType="fitCenter"
                android:text="@string/Mouse"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:theme="@style/FontStyle"/>

            <android.widget.Button
                android:id="@+id/keyBoardMouse"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="3"
                android:background="@android:color/transparent"
                android:drawableTop="@drawable/keyboard_mouse"
                android:scaleType="fitCenter"
                android:text="@string/CompositeMode"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:theme="@style/FontStyle"/>

            <android.widget.Button
                android:id="@+id/question"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@android:color/transparent"
                android:drawableTop="@drawable/question_lg"
                android:scaleType="fitCenter"
                android:text="@string/Instructions"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:theme="@style/FontStyle"/>

            <android.widget.Button
                android:id="@+id/info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@android:color/transparent"
                android:drawableTop="@drawable/info_lg"
                android:scaleType="fitCenter"
                android:text="@string/About"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:theme="@style/FontStyle"/>

            <android.widget.Button
                android:id="@+id/shortcut"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:background="@android:color/transparent"
                android:drawableTop="@drawable/three_dots"
                android:scaleType="fitCenter"
                android:text="@string/ShortCut"
                android:textSize="12sp"
                android:textColor="@color/black"
                android:theme="@style/FontStyle"/>

        </LinearLayout>

        <FrameLayout
            android:id="@+id/fragment_container"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="9"
            android:background="@color/background_light"/>

    </LinearLayout>
    </FrameLayout>

    <!-- Sidebar Navigation Menu -->
    <include
        layout="@layout/nav_menu"
        android:layout_width="@dimen/sidebar_width"
        android:layout_height="match_parent"
        android:layout_gravity="start"/>

</androidx.drawerlayout.widget.DrawerLayout>