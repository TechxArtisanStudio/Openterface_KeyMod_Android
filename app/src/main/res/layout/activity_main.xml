<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1.1"
        android:orientation="horizontal"
        android:paddingTop="3dp">

        <android.widget.Button
            android:id="@+id/usbConnect"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/usb_plug"
            android:scaleType="fitCenter"
            android:text="@string/usbConnect"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/bluetooth"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/bluetooth"
            android:scaleType="fitCenter"
            android:text="@string/bluetooth"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/keyBoard"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/keyboard"
            android:scaleType="fitCenter"
            android:text="@string/KeyBoard"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/mouse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/mouse2"
            android:scaleType="fitCenter"
            android:text="@string/Mouse"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/keyBoardMouse"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="3"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/keyboard_mouse"
            android:scaleType="fitCenter"
            android:text="@string/CompositeMode"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/question"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/question_lg"
            android:scaleType="fitCenter"
            android:text="@string/Instructions"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/info"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/info_lg"
            android:scaleType="fitCenter"
            android:text="@string/About"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

        <android.widget.Button
            android:id="@+id/shortcut"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="2"
            android:background="@android:color/transparent"
            android:drawableTop="@drawable/three_dots"
            android:scaleType="fitCenter"
            android:text="@string/ShortCut"
            android:textSize="12sp"
            android:textColor="@color/black"
            android:theme="@style/FontStyle"/>

    </LinearLayout>

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="9"/>

</LinearLayout>