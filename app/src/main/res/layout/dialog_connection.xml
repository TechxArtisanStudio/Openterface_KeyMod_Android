<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@android:color/white">

    <!-- Fixed Header -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="30dp"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        android:background="@android:color/white"
        android:elevation="4dp">

        <!-- Title -->
        <TextView
            android:id="@+id/title_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="@string/connection_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@android:color/black" />

        <!-- Close Button -->
        <ImageButton
            android:id="@+id/close_button"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:src="@drawable/x_circle"
            android:background="@android:color/transparent"
            android:padding="4dp"
            android:contentDescription="@string/close" />
    </RelativeLayout>

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="500dp"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="12dp">

            <!-- Connection Status -->
            <TextView
                android:id="@+id/connection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/status_disconnected"
                android:textSize="14sp"
                android:textColor="@android:color/darker_gray"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Connection Type Section -->
            <TextView
                android:id="@+id/connection_type_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connection_type"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@android:color/black"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/connection_status"
                app:layout_constraintStart_toStartOf="parent" />

    <!-- USB Connection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/usb_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/connection_type_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/usb_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/usb_plug"
                android:contentDescription="@string/usb_connection" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/usb_connection"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />

                <TextView
                    android:id="@+id/usb_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/not_connected"
                    android:textSize="12sp"
                    android:textColor="@android:color/darker_gray" />
            </LinearLayout>

            <ImageView
                android:id="@+id/usb_status_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_connection_disconnected"
                android:contentDescription="@string/connection_status" />

            <ImageView
                android:id="@+id/usb_signal"
                android:layout_width="20dp"
                android:layout_height="10dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_signal_bars"
                android:tint="@color/primary"
                android:visibility="gone"
                android:contentDescription="Signal strength" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Bluetooth Connection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bluetooth_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="8dp"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/usb_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <ImageView
                android:id="@+id/bluetooth_icon"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/bluetooth"
                android:contentDescription="@string/bluetooth_connection" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bluetooth_connection"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@android:color/black" />

                <TextView
                    android:id="@+id/bluetooth_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/not_connected"
                    android:textSize="12sp"
                    android:textColor="@android:color/darker_gray" />
            </LinearLayout>

            <ImageView
                android:id="@+id/bluetooth_status_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_connection_disconnected"
                android:contentDescription="@string/connection_status" />

            <ImageView
                android:id="@+id/bluetooth_signal"
                android:layout_width="20dp"
                android:layout_height="10dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_signal_bars"
                android:tint="@color/primary"
                android:visibility="gone"
                android:contentDescription="Signal strength" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Auto-connect Option -->
    <CheckBox
        android:id="@+id/auto_connect_checkbox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/auto_connect_on_startup"
        android:layout_marginTop="12dp"
        android:checked="true"
        app:layout_constraintTop_toBottomOf="@id/bluetooth_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Last Connected Info -->
    <TextView
        android:id="@+id/last_connected_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/last_connected_none"
        android:textSize="12sp"
        android:textColor="@android:color/darker_gray"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/auto_connect_checkbox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</LinearLayout>
