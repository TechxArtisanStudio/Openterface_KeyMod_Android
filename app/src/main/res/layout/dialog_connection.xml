<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="@drawable/bg_connection_dialog"
    android:clipToOutline="true">

    <!-- Fixed header (dismiss by tapping outside the dialog or the system back key) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:background="@color/connection_dialog_header_bg">

        <TextView
            android:id="@+id/title_text"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/connection_title"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary" />
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider" />

    <!-- Scrollable Content -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:maxHeight="560dp"
        android:fillViewport="true">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="16dp">

            <!-- Connection Status -->
            <TextView
                android:id="@+id/connection_status"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/status_disconnected"
                android:textSize="14sp"
                android:textColor="@color/text_secondary"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent" />

            <!-- Connection Type Section -->
            <TextView
                android:id="@+id/connection_type_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/connection_type"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary"
                android:layout_marginTop="12dp"
                app:layout_constraintTop_toBottomOf="@id/connection_status"
                app:layout_constraintStart_toStartOf="parent" />

    <!-- Bluetooth Connection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/bluetooth_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/bluetooth_surface"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/connection_type_label"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/bluetooth_connection"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/bluetooth_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/not_connected"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <ImageView
                android:id="@+id/bluetooth_status_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/bluetooth_24px"
                android:contentDescription="@string/connection_status" />

            <ImageView
                android:id="@+id/bluetooth_signal"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/signal_cellular_alt_off_24px"
                android:tint="?attr/colorPrimary"
                android:visibility="gone"
                android:contentDescription="Signal strength" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- USB Connection Card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/usb_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:clickable="true"
        android:focusable="true"
        android:foreground="?android:attr/selectableItemBackground"
        app:cardCornerRadius="8dp"
        app:cardBackgroundColor="@color/bluetooth_surface"
        app:cardElevation="2dp"
        app:layout_constraintTop_toBottomOf="@id/bluetooth_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/usb_connection"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary" />

                <TextView
                    android:id="@+id/usb_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/not_connected"
                    android:textSize="12sp"
                    android:textColor="@color/text_secondary" />
            </LinearLayout>

            <ImageView
                android:id="@+id/usb_status_icon"
                android:layout_width="22dp"
                android:layout_height="22dp"
                android:src="@drawable/ic_usb_off_24"
                android:contentDescription="@string/connection_status" />

            <ImageView
                android:id="@+id/usb_signal"
                android:layout_width="20dp"
                android:layout_height="10dp"
                android:layout_marginStart="4dp"
                android:src="@drawable/ic_signal_bars"
                android:tint="?attr/colorPrimary"
                android:visibility="gone"
                android:contentDescription="Signal strength" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Auto-connect Option -->
    <CheckBox
        android:id="@+id/auto_connect_checkbox"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/auto_connect_on_startup"
        android:textColor="@color/text_primary"
        android:buttonTint="?attr/colorPrimary"
        android:layout_marginTop="12dp"
        android:checked="true"
        app:layout_constraintTop_toBottomOf="@id/usb_card"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Last Connected Info -->
    <TextView
        android:id="@+id/last_connected_info"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/last_connected_none"
        android:textSize="12sp"
        android:textColor="@color/text_secondary"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/auto_connect_checkbox"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent" />

        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>

</LinearLayout>
