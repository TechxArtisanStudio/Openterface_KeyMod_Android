<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/split_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/background_light">

    <!-- Shared top scrolling panel -->
    <FrameLayout
        android:id="@+id/split_top_panel"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"/>

    <!-- Main content: Left Keyboard | Touchpad | Right Keyboard -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left Keyboard -->
        <com.openterface.keymod.CustomKeyboardView
            android:id="@+id/keyboard_view_left"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:keyBackground="@drawable/key_background"
            android:theme="@style/ButtonTheme"/>

        <!-- Touchpad Section (center) -->
        <LinearLayout
            android:id="@+id/touchpad_section"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1.2"
            android:orientation="horizontal">

            <FrameLayout
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@color/touchpad_background">

                <com.openterface.keymod.TouchPadView
                    android:id="@+id/touchPad"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"/>

                <TextView
                    android:id="@+id/touchPadTips"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center"
                    android:gravity="center"
                    android:textColor="@color/text_secondary"
                    android:textSize="11sp"
                    android:padding="12dp"
                    android:background="@android:color/transparent"
                    android:text="Touch Pad&#10;Drag Mode OFF&#10;Single tap -> Click&#10;Double tap -> Double click&#10;Two finger tap -> Right click&#10;Two finger drag -> Scroll&#10;Long press -> Toggle drag mode"/>

            </FrameLayout>

            <!-- Toggle Handle (right side) -->
            <LinearLayout
                android:id="@+id/toggle_handle"
                android:layout_width="36dp"
                android:layout_height="match_parent"
                android:gravity="center"
                android:background="@color/background_light"
                android:clickable="true"
                android:focusable="true">

                <View
                    android:id="@+id/toggle_handle_pill"
                    android:layout_width="4dp"
                    android:layout_height="40dp"
                    android:background="@drawable/toggle_handle_pill"/>

            </LinearLayout>

        </LinearLayout>

        <!-- Right Keyboard -->
        <com.openterface.keymod.CustomKeyboardView
            android:id="@+id/keyboard_view_right"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:keyBackground="@drawable/key_background"
            android:theme="@style/ButtonTheme"/>

    </LinearLayout>

</LinearLayout>
