    <!-- HTML for bold labels (HtmlCompat.fromHtml). -->
    <string name="my_shortcuts_reorder_help_read_mode_block1"><![CDATA[<b>Order</b> — Drag the handle to reorder. <b>Top</b> = first on the keyboard strip; swipe the strip sideways for more pages.]]></string>
    <string name="my_shortcuts_reorder_help_read_mode_block2"><![CDATA[<b>Create</b> — In <b>Favorites</b>, Create adds a new shortcut to <b>General</b> and to Favorites. In <b>General/other tabs</b>, Create adds to that tab only (not Favorites).]]></string>
    <string name="my_shortcuts_reorder_help_read_mode_block3"><![CDATA[<b>Reset</b> — Restores this active built-in profile’s Favorites to fresh-install defaults after confirmation. Custom/imported profiles do not support Reset. <b>Done</b> saves; <b>Cancel</b> discards staged reordering.]]></string>
