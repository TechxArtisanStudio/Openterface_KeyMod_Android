<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="KeyboardButton" parent="Widget.MaterialComponents.Button">
        <item name="android:layout_width">0dp</item>
        <item name="android:layout_height">48dp</item>
        <item name="android:layout_weight">1</item>
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">#212121</item>
        <item name="android:background">@drawable/key_background</item>
        <item name="android:elevation">2dp</item>
        <item name="android:stateListAnimator">@null</item>
    </style>

    <style name="FontStyle" parent="Theme.AppCompat.Light">
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- New shortcut bottom sheet -->
    <style name="Widget.KeyMod.CreateShortcut.Modifier" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="android:minHeight">44dp</item>
        <item name="android:insetTop">0dp</item>
        <item name="android:insetBottom">0dp</item>
        <item name="android:textSize">12sp</item>
        <item name="android:paddingLeft">4dp</item>
        <item name="android:paddingRight">4dp</item>
        <item name="cornerRadius">10dp</item>
    </style>

    <style name="Widget.KeyMod.CreateShortcut.Chip" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipMinHeight">44dp</item>
        <item name="android:textSize">14sp</item>
        <item name="chipCornerRadius">22dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStartPadding">10dp</item>
        <item name="chipEndPadding">10dp</item>
    </style>

    <style name="Widget.KeyMod.CreateShortcut.Chip.Small" parent="Widget.MaterialComponents.Chip.Choice">
        <item name="chipMinHeight">40dp</item>
        <item name="android:textSize">12sp</item>
        <item name="chipCornerRadius">20dp</item>
        <item name="checkedIconVisible">false</item>
        <item name="chipStartPadding">8dp</item>
        <item name="chipEndPadding">8dp</item>
    </style>
</resources>