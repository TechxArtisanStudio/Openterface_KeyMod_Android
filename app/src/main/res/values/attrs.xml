<!-- res/values/attrs.xml -->
<resources>
    <!-- Presentation control rows: idle fill = primary at low opacity (~10%), theme-specific. -->
    <attr name="presentationControlButtonIdleFill" format="color" />

    <declare-styleable name="Keyboard">
        <attr name="keySymbolLabel" format="string" />
        <attr name="keyRequiresShift" format="boolean" />
        <attr name="keyAlternates" format="string" />
        <attr name="keyCornerHint" format="string" />
    </declare-styleable>
</resources>