<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:custom="http://schemas.android.com/apk/res-auto"
    android:keyWidth="10%p"
    android:horizontalGap="0px"
    android:verticalGap="0px"
    android:keyHeight="10%p">

    <Row>
        <Key android:codes="46" android:keyLabel="@string/PrtSc"/>
        <Key android:codes="47" android:keyLabel="@string/ScrLk"/>
        <Key android:codes="48" android:keyLabel="@string/Pause"/>
        <Key android:codes="49" android:keyLabel="@string/Ins" android:horizontalGap="1%p"/>
        <Key android:codes="4A" android:keyLabel="@string/Home"/>
        <Key android:codes="4B" android:keyLabel="@string/PgUp"/>
        <Key android:codes="112" android:keyLabel="@string/Delete" android:horizontalGap="1%p"/>
        <Key android:codes="2A" android:keyLabel="@string/End"/>
        <Key android:codes="4E" android:keyLabel="@string/PgDn"/>
    </Row>

    <Row>
        <Key android:codes="29" android:keyLabel="@string/Esc"/>
        <Key android:codes="3A" android:keyLabel="@string/Function1" android:horizontalGap="0.5%p"/>
        <Key android:codes="3B" android:keyLabel="@string/Function2"/>
        <Key android:codes="3C" android:keyLabel="@string/Function3"/>
        <Key android:codes="3D" android:keyLabel="@string/Function4"/>
        <Key android:codes="3E" android:keyLabel="@string/Function5" android:horizontalGap="0.5%p"/>
        <Key android:codes="3F" android:keyLabel="@string/Function6"/>
        <Key android:codes="40" android:keyLabel="@string/Function7"/>
        <Key android:codes="41" android:keyLabel="@string/Function8"/>
        <Key android:codes="42" android:keyLabel="@string/Function9" android:horizontalGap="0.5%p"/>
        <Key android:codes="43" android:keyLabel="@string/Function10"/>
        <Key android:codes="44" android:keyLabel="@string/Function11"/>
        <Key android:codes="45" android:keyLabel="@string/Function12"/>
    </Row>

    <Row>
        <Key android:codes="35" android:keyLabel="@string/Tilde"/>
        <Key android:codes="1E" android:keyLabel="@string/One_Sigh_Button"/>
        <Key android:codes="1F" android:keyLabel="@string/Two_At_Button"/>
        <Key android:codes="20" android:keyLabel="@string/Three_Pound_Button"/>
        <Key android:codes="21" android:keyLabel="@string/Four_Dollar_Button"/>
        <Key android:codes="22" android:keyLabel="@string/Five_Percent_Button"/>
        <Key android:codes="23" android:keyLabel="@string/Six_Caret_Button"/>
        <Key android:codes="24" android:keyLabel="@string/Seven_Ampersand_Button"/>
        <Key android:codes="25" android:keyLabel="@string/Eight_Asterisk_Button"/>
        <Key android:codes="26" android:keyLabel="@string/Nine_Left_Parenthesis_Button"/>
        <Key android:codes="27" android:keyLabel="@string/Zero_Right_Parenthesis_Button"/>
        <Key android:codes="2D" android:keyLabel="@string/Minus_Sign_Button"/>
        <Key android:codes="2E" android:keyLabel="@string/Plus_Sign_Button"/>
        <Key android:codes="2C" android:keyLabel="@string/BackSpace" android:isRepeatable="true" android:keyWidth="15%p"/>
    </Row>

    <Row android:verticalGap="1%p">
        <Key android:codes="2B" android:keyLabel="@string/TAB" android:keyWidth="15%p"/>
        <Key android:codes="14" android:keyLabel="@string/Q_Button_Upper"/>
        <Key android:codes="1A" android:keyLabel="@string/W_Button_Upper"/>
        <Key android:codes="08" android:keyLabel="@string/E_Button_Upper"/>
        <Key android:codes="15" android:keyLabel="@string/R_Button_Upper"/>
        <Key android:codes="17" android:keyLabel="@string/T_Button_Upper"/>
        <Key android:codes="1C" android:keyLabel="@string/Y_Button_Upper"/>
        <Key android:codes="18" android:keyLabel="@string/U_Button_Upper"/>
        <Key android:codes="0C" android:keyLabel="@string/I_Button_Upper"/>
        <Key android:codes="12" android:keyLabel="@string/O_Button_Upper"/>
        <Key android:codes="13" android:keyLabel="@string/P_Button_Upper"/>
        <Key android:codes="2F" android:keyLabel="@string/Left_Bracket_Button"/>
        <Key android:codes="30" android:keyLabel="@string/Right_Bracket_Button"/>
        <Key android:codes="64" android:keyLabel="@string/Bitwise_OR_Button"/>
    </Row>

    <Row>
        <Key android:codes="39" android:keyLabel="@string/Caps" android:keyWidth="15%p"/>
        <Key android:codes="04" android:keyLabel="@string/A_Button_Upper"/>
        <Key android:codes="16" android:keyLabel="@string/S_Button_Upper"/>
        <Key android:codes="07" android:keyLabel="@string/D_Button_Upper"/>
        <Key android:codes="09" android:keyLabel="@string/F_Button_Upper"/>
        <Key android:codes="0A" android:keyLabel="@string/G_Button_Upper"/>
        <Key android:codes="0B" android:keyLabel="@string/H_Button_Upper"/>
        <Key android:codes="0D" android:keyLabel="@string/J_Button_Upper"/>
        <Key android:codes="0E" android:keyLabel="@string/K_Button_Upper"/>
        <Key android:codes="0F" android:keyLabel="@string/L_Button_Upper"/>
        <Key android:codes="33" android:keyLabel="@string/Colon_Button"/>
        <Key android:codes="34" android:keyLabel="@string/Quotation_Button"/>
        <Key android:codes="28" android:keyLabel="@string/Enter_Button" android:keyWidth="15%p"/>
    </Row>

    <Row>
        <Key android:codes="E1" android:keyLabel="@string/Shift" android:keyWidth="15%p"/>
        <Key android:codes="1D" android:keyLabel="@string/Z_Button_Upper"/>
        <Key android:codes="1B" android:keyLabel="@string/X_Button_Upper"/>
        <Key android:codes="06" android:keyLabel="@string/C_Button_Upper"/>
        <Key android:codes="19" android:keyLabel="@string/V_Button_Upper"/>
        <Key android:codes="05" android:keyLabel="@string/B_Button_Upper"/>
        <Key android:codes="11" android:keyLabel="@string/N_Button_Upper"/>
        <Key android:codes="10" android:keyLabel="@string/M_Button_Upper"/>
        <Key android:codes="36" android:keyLabel="@string/Less_Sign_Button"/>
        <Key android:codes="37" android:keyLabel="@string/Greater_Sign_Button"/>
        <Key android:codes="38" android:keyLabel="@string/Question_Mark"/>

        <Key android:codes="E1" android:keyLabel="@string/Shift" android:keyWidth="15%p"/>
    </Row>

    <Row>
        <Key android:codes="E0" android:keyLabel="@string/Ctrl" android:keyWidth="10%p"/>
        <Key android:codes="E3" android:keyLabel="@string/Win" android:keyWidth="10%p"/>
        <Key android:codes="E2" android:keyLabel="@string/Alt" android:keyWidth="10%p"/>
        <Key android:codes="2C" android:keyLabel="@string/Space_Button" android:keyWidth="30%p"/>

        <Key android:codes="18" android:keyLabel="@string/Alt" android:keyWidth="10%p"/>
        <Key android:codes="1008" android:keyLabel="@string/Win" android:keyWidth="10%p"/>
        <Key android:codes="1007" android:keyLabel="@string/Fn" android:keyWidth="10%p"/>
        <Key android:codes="17" android:keyLabel="@string/Ctrl" android:keyWidth="10%p"/>
    </Row>
</Keyboard>