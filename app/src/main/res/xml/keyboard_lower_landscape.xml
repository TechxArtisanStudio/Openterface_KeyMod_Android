<?xml version="1.0" encoding="utf-8"?>
<Keyboard xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:custom="http://schemas.android.com/apk/res-auto"
    android:keyWidth="10%p"
    android:horizontalGap="0px"
    android:verticalGap="0px"
    android:keyHeight="10%p">

    <Row>
        <Key android:codes="14" android:keyLabel="q" custom:keySymbolLabel="Q" custom:keyAlternates="1" custom:keyCornerHint="1"/>
        <Key android:codes="1A" android:keyLabel="w" custom:keySymbolLabel="W" custom:keyAlternates="2" custom:keyCornerHint="2"/>
        <Key android:codes="08" android:keyLabel="e" custom:keySymbolLabel="E" custom:keyAlternates="3" custom:keyCornerHint="3"/>
        <Key android:codes="15" android:keyLabel="r" custom:keySymbolLabel="R" custom:keyAlternates="4" custom:keyCornerHint="4"/>
        <Key android:codes="17" android:keyLabel="t" custom:keySymbolLabel="T" custom:keyAlternates="5" custom:keyCornerHint="5"/>
        <Key android:codes="1C" android:keyLabel="y" custom:keySymbolLabel="Y" custom:keyAlternates="6" custom:keyCornerHint="6"/>
        <Key android:codes="18" android:keyLabel="u" custom:keySymbolLabel="U" custom:keyAlternates="7" custom:keyCornerHint="7"/>
        <Key android:codes="0C" android:keyLabel="i" custom:keySymbolLabel="I" custom:keyAlternates="8" custom:keyCornerHint="8"/>
        <Key android:codes="12" android:keyLabel="o" custom:keySymbolLabel="O" custom:keyAlternates="9" custom:keyCornerHint="9"/>
        <Key android:codes="13" android:keyLabel="p" custom:keySymbolLabel="P" custom:keyAlternates="0" custom:keyCornerHint="0"/>
    </Row>

    <Row>
        <Key android:codes="04" android:keyLabel="a" custom:keySymbolLabel="A"/>
        <Key android:codes="16" android:keyLabel="s" custom:keySymbolLabel="S"/>
        <Key android:codes="07" android:keyLabel="d" custom:keySymbolLabel="D"/>
        <Key android:codes="09" android:keyLabel="f" custom:keySymbolLabel="F"/>
        <Key android:codes="0A" android:keyLabel="g" custom:keySymbolLabel="G"/>
        <Key android:codes="0B" android:keyLabel="h" custom:keySymbolLabel="H" custom:keyAlternates="-"/>
        <Key android:codes="0D" android:keyLabel="j" custom:keySymbolLabel="J"/>
        <Key android:codes="0E" android:keyLabel="k" custom:keySymbolLabel="K"/>
        <Key android:codes="0F" android:keyLabel="l" custom:keySymbolLabel="L"/>
        <Key android:codes="2A" android:keyLabel="@string/BackSpace" android:isRepeatable="true"/>
    </Row>

    <Row>
        <Key android:codes="E1" android:keyLabel="@string/Shift" android:keyWidth="15%p"/>
        <Key android:codes="1D" android:keyLabel="z" custom:keySymbolLabel="Z"/>
        <Key android:codes="1B" android:keyLabel="x" custom:keySymbolLabel="X"/>
        <Key android:codes="06" android:keyLabel="c" custom:keySymbolLabel="C"/>
        <Key android:codes="19" android:keyLabel="v" custom:keySymbolLabel="V"/>
        <Key android:codes="05" android:keyLabel="b" custom:keySymbolLabel="B"/>
        <Key android:codes="11" android:keyLabel="n" custom:keySymbolLabel="N"/>
        <Key android:codes="10" android:keyLabel="m" custom:keySymbolLabel="M"/>
        <Key android:codes="38" android:keyLabel="/" custom:keySymbolLabel="&#63;" android:keyWidth="15%p"/>
    </Row>

    <Row>
        <Key android:codes="F001" android:keyLabel="@string/Symbols_123" android:keyWidth="15%p"/>
        <Key android:codes="36" android:keyLabel="," custom:keySymbolLabel="&lt;" android:keyWidth="10%p"/>
        <Key android:codes="E3" android:keyLabel="@string/Win" android:keyWidth="10%p"/>
        <Key android:codes="2C" android:keyLabel="@string/Space_Button" android:keyWidth="40%p"/>
        <Key android:codes="37" android:keyLabel="." custom:keySymbolLabel="&gt;" android:keyWidth="10%p"/>
        <Key android:codes="28" android:keyLabel="@string/Enter_Button" android:keyWidth="15%p"/>
    </Row>
</Keyboard>
