<?xml version="1.0" encoding="utf-8"?>
<PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto">

    <!-- Whisper API Section -->
    <PreferenceCategory
        android:title="Whisper API"
        app:iconSpaceReserved="false">

        <EditTextPreference
            android:key="whisper_api_key"
            android:title="API Key"
            android:summary="OpenAI Whisper API key for speech-to-text"
            android:defaultValue=""
            app:useSimpleSummaryProvider="true"
            app:iconSpaceReserved="false" />

        <ListPreference
            android:key="voice_language"
            android:title="Language"
            android:summary="Speech recognition language"
            android:defaultValue="en"
            android:entries="@array/voice_language_names"
            android:entryValues="@array/voice_language_codes"
            app:iconSpaceReserved="false" />

        <SeekBarPreference
            android:key="voice_sensitivity"
            android:title="Sensitivity"
            android:summary="Microphone input level"
            android:defaultValue="80"
            android:max="100"
            app:showSeekBarValue="true"
            app:iconSpaceReserved="false" />

        <SwitchPreferenceCompat
            android:key="enable_voice"
            android:title="Enable voice input"
            android:summary="Allow microphone access for voice input"
            android:defaultValue="true"
            app:iconSpaceReserved="false" />

    </PreferenceCategory>

</PreferenceScreen>
